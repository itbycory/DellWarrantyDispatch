# Dell TechDirect API Credentials
# Register at https://techdirect.dell.com to get these
DELL_CLIENT_ID=your_client_id_here
DELL_CLIENT_SECRET=your_client_secret_here

# Dell API Endpoints (defaults shown - only change if Dell provides different ones)
